*.pkg

# ── Output files từ scripts ───────────────────────────────────
downloaded_from_server.wav
downloaded_from_client.wav
dl_server.wav
dl_client.wav

# ── File WAV tải về / demo (không commit dữ liệu âm thanh) ───
dongbo/*.wav
*.wav
!esp32_client/src/test.wav
!esp32_server/src/test.wav

# ── dongbo: chỉ commit script + hướng dẫn, không commit file tải về
dongbo/downloaded/
dongbo/__pycache__/

# ── Phantom key files (bí mật, không commit) ─────────────────
*.key

# ── Phantom binary bundles (output, không commit) ────────────
*.bin
!folder_test/.gitkeep
!decode/.gitkeep

# ── folder_test / decode output (dữ liệu tải về) ─────────────
folder_test/*.bin
folder_test/output/
decode/output/
decode/*.bin

# ── Phantom output folder (auto-save từ encode.py) ───────────
output/

# ── Phantom demo/test files (không commit dữ liệu thật) ──────
phantom/
!phantom/.gitkeep

# ── Runtime data ─────────────────────────────────────────────
data.json

# ── Credentials / môi trường ─────────────────────────────────
